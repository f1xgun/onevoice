@startuml activity-jwt-rotation
skinparam activityFontSize 12
skinparam activityDiamondFontSize 11
skinparam shadowing false

title Алгоритм ротации JWT-токенов

start

:Пользователь отправляет\nзапрос на вход\n(email, пароль);

:Проверить учётные данные\n(bcrypt);

if (Данные верны?) then (да)
  :Сгенерировать access-токен\n(JWT, срок 15 минут);
  :Сгенерировать refresh-токен\n(случайный, срок 30 дней);
  :Сохранить хеш refresh-токена\nв таблицу refresh_tokens;
  :Вернуть оба токена клиенту;
else (нет)
  :Вернуть ошибку 401;
  stop
endif

:Клиент использует\naccess-токен для запросов;

if (Access-токен истёк?) then (да)
  :Клиент отправляет\nrefresh-токен;
  :Найти запись по хешу\nrefresh-токена;

  if (Токен найден\nи не истёк?) then (да)
    :Удалить старый\nrefresh-токен из БД;
    :Сгенерировать новую пару\naccess + refresh токенов;
    :Сохранить хеш нового\nrefresh-токена в БД;
    :Вернуть новую пару\nтокенов клиенту;
  else (нет)
    :Вернуть ошибку 401;
    :Перенаправить\nна страницу входа;
    stop
  endif
else (нет)
  :Продолжить работу;
endif

if (Пользователь выходит\nиз системы?) then (да)
  :Удалить refresh-токен из БД;
  :Очистить токены на клиенте;
endif

stop

@enduml
