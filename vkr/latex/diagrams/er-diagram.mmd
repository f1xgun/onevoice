erDiagram
    business ||--o{ location : "имеет"
    business ||--o{ channel_account : "подключает"
    business ||--|{ canonical_profile : "задаёт эталон"
    business ||--o{ user_role : "назначает"

    location ||--o{ channel_account : "привязана"

    user ||--o{ user_role : "имеет"
    role ||--o{ user_role : "определяет"

    channel ||--o{ channel_account : "тип"

    channel_account ||--o{ channel_profile_snapshot : "фиксирует срез"
    channel_account ||--o{ event : "получает"

    event ||--o{ conversation_thread : "создаёт"
    conversation_thread ||--o{ message : "содержит"

    event ||--o{ work_item : "порождает"
