# syntax=docker/dockerfile:1.6

# Build stage
FROM golang:1.25-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

ENV GOWORK=off
ENV GOTOOLCHAIN=auto

COPY pkg/go.mod pkg/go.sum ./pkg/
COPY services/agent-telegram/go.mod services/agent-telegram/go.sum ./services/agent-telegram/

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd pkg && for i in 1 2 3; do go mod download && break || sleep 5; done

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd services/agent-telegram && for i in 1 2 3; do go mod download && break || sleep 5; done

COPY pkg/ ./pkg/
COPY services/agent-telegram/ ./services/agent-telegram/

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd services/agent-telegram && CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o /app/bin/agent ./cmd/main.go

# Runtime stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /root/

COPY --from=builder /app/bin/agent .

CMD ["./agent"]
