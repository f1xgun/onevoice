# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git

ENV GOWORK=off
ENV GOTOOLCHAIN=auto

COPY pkg/ ./pkg/
COPY services/agent-yandex-business/ ./services/agent-yandex-business/

RUN cd pkg && go mod download
RUN cd services/agent-yandex-business && go mod download

RUN cd services/agent-yandex-business && CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o /app/bin/agent ./cmd/main.go

# Runtime stage — Playwright requires a full browser environment
FROM mcr.microsoft.com/playwright:v1.50.0-jammy

COPY --from=builder /app/bin/agent /agent

ENTRYPOINT ["/agent"]
